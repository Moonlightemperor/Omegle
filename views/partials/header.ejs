<header class="app-header">
    <div class="app-shell nav-shell">
        <a href="/" class="brand" aria-label="Go to home">
            <span class="brand-icon"><i class="fas fa-video"></i></span>
            <span class="brand-text">Connect</span>
        </a>

        <div class="nav-actions">
            <div class="status-pill" id="connection-status" role="status" aria-live="polite">
                <span class="status-dot"></span>
                <span>Connecting...</span>
            </div>
            <button id="disconnect-btn" class="btn btn-ghost" type="button" title="Disconnect current chat">
                <i class="fas fa-link-slash"></i>
                <span>Disconnect</span>
            </button>
            <button id="next-btn" class="btn btn-secondary" type="button" title="Skip to next stranger">
                <i class="fas fa-forward"></i>
                <span>Next</span>
            </button>
            <button id="video-call-btn" class="btn btn-primary" type="button" title="Start video call">
                <i class="fas fa-video"></i>
                <span>Video Call</span>
            </button>
        </div>
    </div>
</header>