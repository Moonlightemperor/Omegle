<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connect — Chat Room</title>
  <meta name="description" content="You are now in an anonymous chat room. Connect with strangers via text or video.">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="/css/style.css" rel="stylesheet">
</head>

<body class="app-bg">
  <div class="ambient-bg" aria-hidden="true">
    <div class="blob blob-a"></div>
    <div class="blob blob-b"></div>
    <div class="blob blob-c"></div>
  </div>

  <div class="chat-layout">
    <%- include('partials/header') %>

    <!-- ── Video overlay ────────────────────────────────────────────── -->
    <div class="video-overlay videoblock hidden">
      <div id="videos" class="videos-stage">
        <video class="video-player" id="remoteVideo" autoplay playsinline></video>
        <video class="video-player smallFrame" id="localVideo" autoplay muted playsinline></video>
      </div>

      <div id="controls" class="video-controls">
        <button class="video-btn" id="cameraButton" title="Toggle Camera" aria-label="Toggle camera" type="button">
          <i class="fas fa-video"></i>
        </button>
        <button class="video-btn video-btn-danger" id="hangup" title="End Call" aria-label="End call" type="button">
          <i class="fas fa-phone-slash"></i>
        </button>
        <button class="video-btn" id="micButton" title="Toggle Microphone" aria-label="Toggle microphone" type="button">
          <i class="fas fa-microphone"></i>
        </button>
        <button class="video-btn" id="screenshare-btn" title="Share Screen" aria-label="Share screen" type="button">
          <i class="fas fa-desktop"></i>
        </button>
      </div>
    </div>

    <!-- ── Permission denied ─────────────────────────────────────────── -->
    <div id="perm-denied" class="call-modal hidden">
      <div class="call-card card perm-card">
        <div class="call-icon" style="background: linear-gradient(135deg, #ff5a79, #d82b56);">
          <i class="fas fa-video-slash"></i>
        </div>
        <h3>Camera Access Denied</h3>
        <p>Please allow camera and microphone access in your browser settings, then try again.</p>
        <div class="call-tips" style="margin-top:0.75rem;">
          <span><i class="fas fa-lock-open"></i> Click the lock icon in your browser address bar</span>
          <span><i class="fas fa-rotate-right"></i> Reload the page after granting permission</span>
        </div>
        <div class="call-actions">
          <button id="perm-retry" class="btn btn-primary" type="button">
            <i class="fas fa-rotate-right"></i> Try Again
          </button>
        </div>
      </div>
    </div>

    <!-- ── Incoming call modal ────────────────────────────────────────── -->
    <div id="incoming-call" class="call-modal hidden">
      <div class="call-card card">
        <div class="call-head">
          <div class="call-icon"><i class="fas fa-phone-volume"></i></div>
          <span class="call-status"><i class="fas fa-circle"></i> Live request</span>
        </div>
        <h3>Incoming Video Call</h3>
        <p><strong>Stranger</strong> wants to connect with you on video.</p>
        <div class="call-tips">
          <span><i class="fas fa-user-shield"></i> Stay anonymous</span>
          <span><i class="fas fa-video"></i> Camera optional</span>
        </div>
        <div class="call-actions">
          <button id="accept-call" class="btn btn-success" type="button">
            <i class="fas fa-phone"></i>
            <span>Accept</span>
          </button>
          <button id="reject-call" class="btn btn-danger" type="button">
            <i class="fas fa-xmark"></i>
            <span>Reject</span>
          </button>
        </div>
      </div>
    </div>

    <!-- ── Chat window ────────────────────────────────────────────────── -->
    <main class="chat-main app-shell">
      <section class="chat-window card" id="message-container">
        <div class="waiting-state nobody">
          <div class="waiting-icon"><i class="fas fa-comments"></i></div>
          <h3>Looking for someone to chat with...</h3>
          <p>Stay ready. You will be connected automatically.</p>
          <div class="typing-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="typing-indicator hidden" id="typing-indicator">
          <i class="fas fa-ellipsis"></i>
          <span>Stranger is typing...</span>
        </div>
      </section>
    </main>

    <!-- ── Compose bar ─────────────────────────────────────────────────── -->
    <form id="chatform" class="chat-compose">
      <div class="app-shell compose-shell">
        <input type="hidden" id="userid" value="">

        <!-- Emoji picker -->
        <div class="emoji-wrap">
          <button type="button" id="emoji-toggle" class="btn btn-ghost icon-only" aria-label="Open emoji picker" title="Emoji">
            <i class="fas fa-face-smile"></i>
          </button>
          <div id="emoji-picker" class="emoji-picker hidden" role="listbox" aria-label="Emoji picker"></div>
        </div>

        <div class="input-wrap">
          <i class="fas fa-message"></i>
          <textarea id="messagebox" placeholder="Type a message… (Enter to send)" rows="1" autocomplete="off"></textarea>
        </div>
        <button type="submit" class="btn btn-primary icon-only" aria-label="Send message" title="Send">
          <i class="fas fa-paper-plane"></i>
        </button>
      </div>
    </form>

    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>
  </div>

  <!-- Socket.IO -->
  <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"
    integrity="sha384-2huaZvOR9iDzHqslqwpR87isEmrfxqyWOF7hr7BY6KG0+hVKLoEXMPUJw3ynWuhO"
    crossorigin="anonymous"></script>

  <!-- Chat logic (extracted) -->
  <script src="/js/chat.js" defer></script>
</body>

</html>