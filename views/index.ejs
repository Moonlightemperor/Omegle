<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connect - Random Video Chat</title>
  <link href="/css/style.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="app-bg">
  <div class="ambient-bg" aria-hidden="true">
    <div class="blob blob-a"></div>
    <div class="blob blob-b"></div>
    <div class="blob blob-c"></div>
  </div>

  <main class="auth-layout">
    <section class="card hero-card">
      <div class="hero-icon">
        <i class="fas fa-video"></i>
      </div>

      <p class="hero-badge"><i class="fas fa-sparkles"></i> Smart random matching</p>
      <h1>Connect with new people in seconds</h1>
      <p class="hero-copy">
        A clean, anonymous chat experience designed for fast conversations with text and video.
      </p>

      <div class="feature-list">
        <div class="feature-item">
          <i class="fas fa-user-shield"></i>
          <div>
            <h3>Privacy first</h3>
            <p>No account needed to start chatting.</p>
          </div>
        </div>
        <div class="feature-item">
          <i class="fas fa-earth-americas"></i>
          <div>
            <h3>Global connections</h3>
            <p>Meet people from around the world instantly.</p>
          </div>
        </div>
        <div class="feature-item">
          <i class="fas fa-bolt"></i>
          <div>
            <h3>Fast matching</h3>
            <p>Get paired quickly and start talking right away.</p>
          </div>
        </div>
      </div>

      <a href="/chat" class="btn btn-primary btn-lg">
        <i class="fas fa-comments"></i>
        <span>Start Chatting</span>
      </a>
      <p class="muted-note">By continuing, you agree to basic community guidelines.</p>
    </section>
  </main>
</body>

</html>